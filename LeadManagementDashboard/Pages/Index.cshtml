@page
@model IndexModel
@{
    ViewData["Title"] = "Lead Management Board";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Lead Management Dashboard</h2>
        <span class="badge bg-secondary">Total Columns: @Model.Columns.Count</span>
    </div>

    @if (!string.IsNullOrEmpty(Model.ToastMessage))
    {
        <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 11">
            <div id="statusToast" class="toast align-items-center text-white bg-@Model.ToastType border-0 show" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        @Model.ToastMessage
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <div class="row flex-nowrap overflow-auto pb-4">
        @foreach (var column in Model.Columns)
        {
            <div class="col-12 col-md-6 col-lg-3">
                <div class="card bg-light shadow-sm border-0 h-100">
                    <div class="card-header text-white fw-bold d-flex justify-content-between align-items-center"
                         style="background-color: @column.ColorCode;">
                        <span>@column.Name</span>
                        <span class="badge bg-white text-dark rounded-pill">@column.Leads.Count</span>
                    </div>

                    <div class="card-body overflow-auto p-2" style="max-height: 75vh; min-height: 300px;">
                        @if (!column.Leads.Any())
                        {
                            <div class="text-center text-muted my-5">
                                <p class="fst-italic">No leads</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var lead in column.Leads)
                            {
                                <div class="card mb-3 shadow-sm border-start border-4" style="border-left-color: @column.ColorCode !important;">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <h6 class="card-title fw-bold mb-1" style="cursor: pointer;" onclick="loadLeadDetails(@lead.Id)">
                                                <a href="javascript:void(0)" class="text-decoration-none text-dark">@lead.FullName</a>
                                            </h6>
                                        </div>
                                        <p class="text-muted small mb-1"><strong>Company:</strong> @lead.Company</p>
                                        <p class="text-muted small mb-3"><strong>Email:</strong> @lead.Email</p>

                                        <div class="d-flex justify-content-between pt-2 border-top">
                                            <form method="post" asp-page-handler="Move">
                                                <input type="hidden" name="leadId" value="@lead.Id" />
                                                <input type="hidden" name="moveForward" value="false" />
                                                <button type="submit" class="btn btn-outline-secondary btn-sm" @(lead.CanMoveBackward ? "" : "disabled") title="Move Backward">
                                                    &larr; Back
                                                </button>
                                            </form>

                                            <form method="post" asp-page-handler="Move">
                                                <input type="hidden" name="leadId" value="@lead.Id" />
                                                <input type="hidden" name="moveForward" value="true" />
                                                <button type="submit" class="btn btn-primary btn-sm" @(lead.CanMoveForward ? "" : "disabled") title="Move Forward">
                                                    Next &rarr;
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="leadDetailsModal" tabindex="-1" aria-labelledby="leadDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalLeadName">Lead Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <p><strong>Email:</strong> <span id="modalLeadEmail"></span></p>
                    <p><strong>Phone:</strong> <span id="modalLeadPhone"></span></p>
                    <p><strong>Company:</strong> <span id="modalLeadCompany"></span></p>
                    <p><strong>Current Status:</strong> <span id="modalLeadStatus" class="badge bg-info"></span></p>
                </div>
                <hr />
                <h6>Activity History</h6>
                <ul class="list-group list-group-flush" id="modalActivityList">
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-hide Toast after 4 seconds
        document.addEventListener('DOMContentLoaded', function () {
            var toastEl = document.getElementById('statusToast');
            if (toastEl) {
                var toast = new bootstrap.Toast(toastEl, { delay: 4000 });
                toast.show();
            }
        });

        // AJAX Activity History Loader
        async function loadLeadDetails(leadId) {
            const response = await fetch(`/?handler=LeadDetails&id=${leadId}`);
            if (response.ok) {
                const lead = await response.json();
                document.getElementById('modalLeadName').innerText = lead.fullName;
                document.getElementById('modalLeadEmail').innerText = lead.email;
                document.getElementById('modalLeadPhone').innerText = lead.phone;
                document.getElementById('modalLeadCompany').innerText = lead.company;
                document.getElementById('modalLeadStatus').innerText = lead.statusName;

                const activityList = document.getElementById('modalActivityList');
                activityList.innerHTML = '';

                if (lead.activities.length === 0) {
                    activityList.innerHTML = '<li class="list-group-item text-muted">No activity recorded yet.</li>';
                } else {
                    lead.activities.forEach(act => {
                        const date = new Date(act.changedAt).toLocaleString();
                        const fromState = act.fromStatusName ? act.fromStatusName : 'Created';
                        const item = `<li class="list-group-item d-flex justify-content-between align-items-start">
                            <div>
                                <div>Moved from <strong>${fromState}</strong> to <strong>${act.toStatusName}</strong></div>
                                <small class="text-muted">${act.notes}</small>
                            </div>
                            <span class="badge bg-light text-dark">${date}</span>
                        </li>`;
                        activityList.innerHTML += item;
                    });
                }

                var modal = new bootstrap.Modal(document.getElementById('leadDetailsModal'));
                modal.show();
            }
        }
    </script>
}